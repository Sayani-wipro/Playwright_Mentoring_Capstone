{
  "name": "playwright-lab",
  "version": "1.0.0",
  "description": "Week-wise Playwright suite with fixtures, mocking, artifacts, CI matrix, accessibility and visual checks",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:update-snapshots": "playwright test --update-snapshots",
    "report": "playwright show-report",
    "results:summary": "node scripts/summarize-results.js"
  },
  "type": "commonjs",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0"
  }
}
